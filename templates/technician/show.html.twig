{% extends 'base.html.twig' %}

{% block title %}Technician{% endblock %}

{% block body %}
    <h1>Technician</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ technician.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ technician.name }}</td>
            </tr>
            <tr>
                <th>Surname</th>
                <td>{{ technician.surname }}</td>
            </tr>
            <tr>
                <th>Active</th>
                <td>{{ technician.active ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_technician_index') }}">back to list</a>

    <a href="{{ path('app_technician_edit', {'id': technician.id}) }}">edit</a>

    {{ include('technician/_delete_form.html.twig') }}
{% endblock %}
